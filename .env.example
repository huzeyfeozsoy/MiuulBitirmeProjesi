# =========================================================
# SmartClub 360 - Environment Variables Example
# =========================================================
# Bu dosyayi `.env` olarak kopyalayip kendi degerlerinizi giriniz.
#   PowerShell:  Copy-Item .env.example .env
#   Bash:        cp .env.example .env
# .env dosyasi git'e gonderilmez (.gitignore ile haric tutulmustur).
# =========================================================

# football-data.org API Token
# Ucretsiz token almak icin: https://www.football-data.org/client/register
FOOTBALL_DATA_API_TOKEN=your_api_token_here
